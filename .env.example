# Copy this file to .env and fill in real values.
# .env is listed in .gitignore — it will never be committed.

# Password for the local PostgreSQL container (can be anything for local dev)
DB_PASSWORD=devpassword

# Ratings API key — replace with the value your instructor provides
# After Step 3 of the lab this is also set via dotnet user-secrets for local dev
RATINGS_API_KEY=sk-replace-me-with-real-key
